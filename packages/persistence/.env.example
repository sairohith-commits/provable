# Provable persistence — local dev database (Phase 3). Copy to .env for local work.
#
# DATABASE_URL — the APPLICATION connection (role `provable_app`). RLS-enforced.
#                All app queries go through this role via withTenant().
# DIRECT_URL   — the DIRECT, non-pooled SUPERUSER connection. Used by
#                `prisma migrate` (DDL + grants + RLS policies) ONLY. Never by app code.
#
# Local Docker Postgres listens on host port 5434 (see ../../docker-compose.yml).
DATABASE_URL="postgresql://provable_app:provable_app@localhost:5434/provable?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5434/provable?schema=public"
