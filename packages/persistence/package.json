{
  "name": "@provable/persistence",
  "version": "0.0.0",
  "private": true,
  "description": "Provable persistence — Prisma + Postgres RLS tenant data layer. Anti-corruption: maps rows → @provable/contracts, never leaks Prisma types.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "prisma:generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "typecheck": "prisma generate && tsc -p tsconfig.json",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@provable/contracts": "workspace:*",
    "@provable/core": "workspace:*"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "6.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
