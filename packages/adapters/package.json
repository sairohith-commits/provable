{
  "name": "@provable/adapters",
  "version": "0.0.0",
  "private": true,
  "description": "Provable adapters — anti-corruption connectors that validate external data and map it to canonical Decisions. Imports @provable/contracts ONLY (among workspace packages); never core/persistence/apps.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@provable/contracts": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
