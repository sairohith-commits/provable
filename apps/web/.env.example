# @provable/web — copy to .env.local (gitignored).

# ── Auth provider selection (Phase A) ────────────────────────────────────────
# Exactly one active per instance. Defaults to `clerk` (the existing hosted deploy).
# A missing/misconfigured active provider FAILS LOUDLY at startup (no silent fallback).
AUTH_PROVIDER="clerk"   # clerk | oidc | local

# clerk (multi-tenant; orgId from the verified Clerk session). Dev keys provided by Rohith.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# oidc (self-hosted, SINGLE-ORG; Authorization Code + PKCE against a configured issuer).
# OIDC_ISSUER="https://issuer.example.com"
# OIDC_CLIENT_ID="provable"
# OIDC_CLIENT_SECRET="..."
# OIDC_REDIRECT_URI="http://localhost:3020/api/auth/callback"
# OIDC_ALLOW_INSECURE="false"   # set true ONLY for http issuers in dev/test
# WORKSPACE_ORG_ID="org_..."    # the single Provable org this instance serves
# AUTH_SESSION_SECRET="<>=32 random chars>"

# local (self-hosted, SINGLE-ORG; bootstrapped admin for air-gapped/trial).
# The password is stored ONLY as a bcrypt hash — never plaintext.
# LOCAL_ADMIN_EMAIL="admin@example.com"
# LOCAL_ADMIN_PASSWORD_HASH="$2b$12$....."   # bcrypt hash of the admin password
# WORKSPACE_ORG_ID="org_..."
# AUTH_SESSION_SECRET="<>=32 random chars>"

# Read API (server-only). The internal token MUST equal the API's PROVABLE_INTERNAL_TOKEN.
# These are server-only and never reach the browser. Web gets NO DATABASE_URL.
PROVABLE_API_URL="http://localhost:3010"
PROVABLE_INTERNAL_TOKEN="same-as-api"
