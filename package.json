{
  "name": "provable",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1",
    "lint": "turbo run lint",
    "depcruise": "depcruise \"packages/*/src\" \"apps/*/src\" --config .dependency-cruiser.cjs",
    "arch:guard": "node scripts/arch-gate-guard.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "dependency-cruiser": "^16.10.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
