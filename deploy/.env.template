# ── Provable BYOC — instance config. Copy to deploy/.env and fill in. ──────────────────
# Bring up:  docker compose -f deploy/docker-compose.yml --env-file deploy/.env up --build
# NOTHING here phones home. The only outbound call is your configured LLM upstream (gateway).

# ── Bundled Postgres (the `postgres` service). Omit if pointing at an external managed DB. ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-owner-password
POSTGRES_DB=provable

# ── Database connections (the RLS-role model — DO NOT collapse to one URL) ──────────────
# DATABASE_URL = the NON-OWNER, RLS-scoped app role. The api boots ONLY on this (startup RLS
# assertion). APP_DB_PASSWORD must equal this role's password. APP_DB_ROLE defaults provable_app.
APP_DB_ROLE=provable_app
APP_DB_PASSWORD=change-me-strong-app-password
DATABASE_URL=postgresql://provable_app:change-me-strong-app-password@postgres:5432/provable
# DIRECT_URL = the OWNER/superuser connection. Migrations + role-create + SECURITY DEFINER only.
DIRECT_URL=postgresql://postgres:change-me-strong-owner-password@postgres:5432/provable

# ── Web ↔ API internal channel (shared secret; generate a strong random value) ──────────
PROVABLE_INTERNAL_TOKEN=change-me-strong-internal-token
PROVABLE_API_URL=http://api:3000

# ── Single workspace org + first Owner (seeded idempotently by the bootstrap; no lockout) ──
WORKSPACE_ORG_ID=org_main
BOOTSTRAP_OWNER_EMAIL=owner@your-company.example

# ── Self-hosted auth (Phase A) — NO Clerk required. Choose oidc or local. ───────────────
AUTH_PROVIDER=local
AUTH_SESSION_SECRET=change-me-at-least-32-chars-long-secret

# local: a single bootstrapped admin. Hash: `node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'your-password'`
LOCAL_ADMIN_EMAIL=owner@your-company.example
LOCAL_ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# oidc: point at your IdP (set AUTH_PROVIDER=oidc). email_verified is required to bind invites.
# OIDC_ISSUER=https://idp.your-company.example
# OIDC_CLIENT_ID=provable
# OIDC_CLIENT_SECRET=change-me
# OIDC_REDIRECT_URI=https://provable.your-company.example/api/auth/callback

# ── Gateway upstream (Tier-1 Observe-only LLM proxy). Your provider; BYO key per request. ──
PROVABLE_GATEWAY_UPSTREAM=https://api.openai.com

# ── Optional, OFFLINE license slot — read + logged only, never validated, never phones home. ──
# LICENSE_KEY=

# ── Host port mappings ──
API_PORT=3010
WEB_PORT=3020
